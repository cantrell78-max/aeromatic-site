---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, formspreeAction } from "../config/site";
---

<BaseLayout title="Contact" description="Contact Aeromatic Drone Services for aerial photography and drone work in Bend, Oregon and the West Coast.">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Request a shoot</h1>
      <p class="lead">
        Tell us about your property, event, or site. We'll follow up with availability and pricing.
      </p>

      <div class="contact-grid">
        {
          formspreeAction ? (
            <form class="card contact-form" action={formspreeAction} method="POST">
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="message">Project details</label>
                <textarea id="message" name="message" rows="5" required placeholder="Location, date, type of shoot…"></textarea>
              </div>
              <button type="submit" class="btn">Send message</button>
            </form>
          ) : (
            <div class="card contact-form contact-form--pending">
              <h3 style="margin-top: 0">Email us directly</h3>
              <p style="margin: 0; color: var(--text-muted)">
                The contact form will go live once Formspree is connected. For now, reach out by email:
              </p>
              {
                site.contactEmail ? (
                  <p style="margin: 1rem 0 0">
                    <a href={`mailto:${site.contactEmail}`} class="btn">{site.contactEmail}</a>
                  </p>
                ) : (
                  <p class="mono" style="font-size: 0.8rem; margin: 1rem 0 0; color: var(--text-muted)">
                    Add <code>PUBLIC_CONTACT_EMAIL</code> or <code>PUBLIC_FORMSPREE_ID</code> in a <code>.env</code> file (see <code>env.example</code>).
                  </p>
                )
              }
            </div>
          )
        }

        <div>
          <div class="card" style="margin-bottom: 1.25rem">
            <h3 style="margin-top: 0">Service area</h3>
            <p style="margin: 0; color: var(--text-muted)">
              Bend, Oregon · Oregon · California · Washington · select national projects
            </p>
            <p style="margin: 1rem 0 0">
              <a href="https://www.google.com/maps/search/?api=1&query=Bend+Oregon" target="_blank" rel="noopener noreferrer">
                Find us on Google Maps →
              </a>
            </p>
            {
              site.youtubeUrl && (
                <p style="margin: 1rem 0 0">
                  <a href={site.youtubeUrl} target="_blank" rel="noopener noreferrer">
                    YouTube channel →
                  </a>
                </p>
              )
            }
          </div>
          <div class="map-wrap">
            <iframe
              src={site.mapsEmbedSrc}
              title="Map — Bend, Oregon service area"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-form button {
    cursor: pointer;
    border: none;
    font: inherit;
  }

  .contact-form--pending {
    border-color: var(--border);
  }
</style>