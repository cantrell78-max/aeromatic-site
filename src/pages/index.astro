---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { site } from "../config/site";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const heroImage = "/images/hero/hero.webp";
const heroOnDisk = fs.existsSync(path.join(process.cwd(), "public", "images", "hero", "hero.webp"));
---

<BaseLayout title="Home">
  <section class="hero" class:list={[{ "hero--has-image": heroOnDisk }]}>
    {
      heroOnDisk && (
        <div class="hero__media" aria-hidden="true">
          <img src={heroImage} alt="" width={2400} height={1350} fetchpriority="high" decoding="async" />
        </div>
      )
    }
    <div class="container hero__inner">
      <p class="eyebrow mono">Drone services · Aerial photography</p>
      <h1>Clarity from above.</h1>
      <p class="lead">
        {site.name} delivers cinematic aerial imagery for real estate, events, and mapping — based in {site.location}, available across the West Coast and beyond.
      </p>
      <div class="hero__actions">
        <a href="/gallery/" class="btn">View gallery</a>
        <a href="/contact/" class="btn btn--ghost">Request a shoot</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Capabilities</p>
      <h2>What we fly</h2>
      <div class="grid-services">
        <article class="card">
          <h3>Real estate</h3>
          <p>Listings, developments, and property marketing with crisp aerial stills and video.</p>
        </article>
        <article class="card">
          <h3>Mapping &amp; topo</h3>
          <p>Orthomosaic, site context, and terrain-aware visuals for planning and documentation.</p>
        </article>
        <article class="card">
          <h3>Events &amp; film</h3>
          <p>Outdoor events, promotional reels, and edited deliverables for your brand.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">Journal</p>
      <h2>Latest from the blog</h2>
      {
        posts.length > 0 ? (
          <ul class="blog-list">
            {posts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </li>
            ))}
          </ul>
        ) : (
          <p class="lead">Posts will appear here once published.</p>
        )
      }
      <p style="margin-top: 1.5rem">
        <a href="/blog/">All posts →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero--has-image {
    padding: 6rem 0 5rem;
    min-height: min(72vh, 42rem);
    display: flex;
    align-items: flex-end;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(8, 9, 12, 0.92) 0%,
      rgba(8, 9, 12, 0.75) 45%,
      rgba(8, 9, 12, 0.35) 100%
    );
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 40rem;
  }

  .hero--has-image .hero__inner {
    text-shadow: 0 1px 24px rgba(0, 0, 0, 0.5);
  }

  .hero:not(.hero--has-image) {
    background: linear-gradient(180deg, rgba(62, 224, 208, 0.04) 0%, transparent 55%);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }
</style>