# Copy to .env and fill in (never commit .env)
# PUBLIC_ vars are available in the browser

# Formspree — https://formspree.io → New form → copy id from URL
# Default in site.ts is mrevblgq — set here only to override
PUBLIC_FORMSPREE_ID=mrevblgq

# Google Business Profile → Share → Embed a map → paste iframe src URL
PUBLIC_MAPS_EMBED_SRC=

# Optional
PUBLIC_YOUTUBE_URL=https://www.youtube.com/channel/UC53h4kF3hK4m7WxdrldUMog
PUBLIC_CONTACT_EMAIL=