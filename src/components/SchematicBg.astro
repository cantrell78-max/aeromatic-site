---
/** Faint HUD / blueprint layer behind page content */
---
<div class="schematic-bg" aria-hidden="true">
  <svg class="schematic-bg__svg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice">
    <defs>
      <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.35" />
      </pattern>
      <linearGradient id="fade" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#08090c" stop-opacity="0.3" />
        <stop offset="50%" stop-color="#08090c" stop-opacity="0.85" />
        <stop offset="100%" stop-color="#08090c" stop-opacity="1" />
      </linearGradient>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid)" />
    <g stroke="currentColor" fill="none" stroke-width="0.6" opacity="0.25">
      <circle cx="600" cy="400" r="180" />
      <circle cx="600" cy="400" r="120" stroke-dasharray="4 8" />
      <line x1="0" y1="400" x2="1200" y2="400" />
      <line x1="600" y1="0" x2="600" y2="800" />
      <path d="M 420 520 L 600 280 L 780 520 L 600 440 Z" opacity="0.4" />
      <path d="M 200 200 L 280 240 L 200 280 Z" fill="currentColor" opacity="0.08" />
      <path d="M 920 560 L 1000 600 L 920 640 Z" fill="currentColor" opacity="0.08" />
    </g>
    <text x="48" y="64" fill="currentColor" font-family="monospace" font-size="11" opacity="0.35">
      AEROMATIC // GRID REF
    </text>
    <text x="48" y="84" fill="currentColor" font-family="monospace" font-size="10" opacity="0.25">
      ALT 400FT · HDG 270° · SYS NOMINAL
    </text>
    <rect width="100%" height="100%" fill="url(#fade)" />
  </svg>
</div>

<style>
  .schematic-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    color: var(--accent-dim, #2a9d92);
    overflow: hidden;
  }

  .schematic-bg__svg {
    width: 100%;
    height: 100%;
    opacity: 0.55;
  }
</style>