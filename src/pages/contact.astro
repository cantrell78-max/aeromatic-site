---
import BaseLayout from "../layouts/BaseLayout.astro";

/** Replace with your Google Maps embed URL from Share → Embed a map */
const mapsEmbedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d27244.0!2d-121.3153!3d44.0582!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54b6c7c9c8b8b8b9%3A0x1!2sBend%2C%20OR!5e0!3m2!1sen!2sus!4v1";
---

<BaseLayout title="Contact" description="Contact Aeromatic Drone Services for aerial photography and drone work in Bend, Oregon and the West Coast.">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Request a shoot</h1>
      <p class="lead">
        Tell us about your property, event, or site. We'll follow up with availability and pricing.
      </p>

      <div class="contact-grid">
        <form
          class="card contact-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
        >
          <p class="mono" style="font-size: 0.8rem; color: var(--warm); margin-top: 0">
            Replace form <code>action</code> with your Formspree ID (or Netlify Forms) in <code>contact.astro</code>.
          </p>
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="message">Project details</label>
            <textarea id="message" name="message" rows="5" required placeholder="Location, date, type of shoot…"></textarea>
          </div>
          <button type="submit" class="btn">Send message</button>
        </form>

        <div>
          <div class="card" style="margin-bottom: 1.25rem">
            <h3 style="margin-top: 0">Service area</h3>
            <p style="margin: 0; color: var(--text-muted)">
              Bend, Oregon · Oregon · California · Washington · select national projects
            </p>
            <p style="margin: 1rem 0 0">
              <a href="https://www.google.com/maps/search/?api=1&query=Bend+Oregon" target="_blank" rel="noopener noreferrer">
                Find us on Google Maps →
              </a>
            </p>
          </div>
          <div class="map-wrap">
            <iframe
              src={mapsEmbedSrc}
              title="Map — Bend, Oregon service area"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
          <p class="mono" style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.75rem">
            Swap the iframe <code>src</code> in contact.astro with your Business Profile embed code.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-form button {
    cursor: pointer;
    border: none;
    font: inherit;
  }
</style>