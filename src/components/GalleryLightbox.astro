---
import type { GalleryImage } from "../lib/gallery";
import "photoswipe/style.css";

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

{
  images.length > 0 ? (
    <div id="gallery" class="gallery-masonry">
      {images.map((img) => (
        <a
          href={img.src}
          class="gallery-masonry__item"
          data-pswp-width={img.width}
          data-pswp-height={img.height}
          aria-label={`View full size: ${img.title}`}
        >
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            decoding="async"
            width={img.width}
            height={img.height}
          />
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state gallery-masonry__empty">
      <p>
        <strong>No gallery images yet.</strong>
      </p>
      <p>
        Add images to <code>public/gallery/</code> and deploy.
      </p>
    </div>
  )
}

<style>
  .gallery-masonry {
    column-count: 3;
    column-gap: 0.75rem;
    margin-top: 2rem;
  }

  .gallery-masonry__item {
    display: block;
    break-inside: avoid;
    margin-bottom: 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    overflow: hidden;
    cursor: zoom-in;
    line-height: 0;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .gallery-masonry__item:hover {
    border-color: var(--accent-dim);
    box-shadow: 0 0 20px var(--glow);
  }

  .gallery-masonry__item img {
    width: 100%;
    height: auto;
    display: block;
    vertical-align: middle;
  }

  .gallery-masonry__empty {
    margin-top: 2rem;
  }

  @media (max-width: 1024px) {
    .gallery-masonry {
      column-count: 2;
    }
  }

  @media (max-width: 520px) {
    .gallery-masonry {
      column-count: 1;
    }
  }

  :global(.pswp) {
    --pswp-bg: #08090c;
    --pswp-icon-color: #e8ecf4;
    --pswp-icon-color-secondary: #8b93a8;
    --pswp-icon-stroke-color: #252b38;
    --pswp-icon-stroke-width: 1px;
    --pswp-error-text-color: var(--pswp-icon-color);
  }
</style>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";

  const lightbox = new PhotoSwipeLightbox({
    gallery: "#gallery",
    children: "a",
    pswpModule: () => import("photoswipe"),
    wheelToZoom: true,
    bgOpacity: 0.92,
  });

  lightbox.init();
</script>