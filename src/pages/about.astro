---
import BaseLayout from "../layouts/BaseLayout.astro";

const headshot = "/images/about/adam.jpg";
---

<BaseLayout
  title="About"
  description="About Aeromatic Drone Services — aviation background, real estate aerial work, and the story behind the name."
>
  <section class="section">
    <div class="container about">
      <p class="eyebrow">About</p>
      <h1>The person behind the lens</h1>

      <div class="about__grid">
        <div class="about__photo card">
          <img
            src={headshot}
            alt="Portrait of Adam — Aeromatic Drone Services"
            width={960}
            height={1200}
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="about__copy prose">
          <p>
            Hi, I'm <strong>Adam Cantrell</strong> — this is <strong>Aeromatic Drone Services</strong>, built on a lifelong pull toward flight, precision, and storytelling from above.
          </p>

          <h2>Aviation &amp; photography</h2>
          <p>
            My grandfather was a private pilot who flew Cessnas. I went to Space Camp as a kid, started flight instruction at fifteen, and aviation has stayed a hobby ever since.
          </p>
          <p>
            I've worked with multiple real estate companies across the West Coast, combining a passion for photography and technology with dependable deliverables listing agents and developers can use immediately.
          </p>

          <h2>Why Aeromatic</h2>
          <p>
            The name <strong>Aeromatic</strong> nods to my grandfather's HVAC company, <strong>Airomatic</strong>: air, automation, and craftsmanship. Different trade, same family.
          </p>

          <h2>Coverage</h2>
          <p>
            Based in <strong>Bend, Oregon</strong>, available throughout Oregon, California, and Washington, with select projects in Hawaii, Colorado, Alaska, and beyond. Services include real estate aerials, topological mapping support, events, videography, and edited media deliverables.
          </p>

          <p>
            <a href="/contact/" class="btn">Get in touch</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about__grid {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .about__grid {
      grid-template-columns: minmax(240px, 320px) 1fr;
      align-items: start;
    }
  }

  .about__photo {
    padding: 0;
    overflow: hidden;
  }

  .about__photo img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

</style>